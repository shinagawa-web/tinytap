#!/usr/bin/env bash
# pre-push: run tests and enforce 100% coverage on pure-Go packages before push.
set -euo pipefail

PKGS="./internal/output/tui/ ./internal/proc/ ./internal/protocols/http/"
COVFILE=$(mktemp /tmp/tinytap-prepush-XXXXXX.out)
trap 'rm -f "${COVFILE}"' EXIT

echo "==> Running tests..."
if ! go test -coverprofile="${COVFILE}" -covermode=atomic ${PKGS}; then
    echo "FAIL: tests failed"
    exit 1
fi

total=$(go tool cover -func="${COVFILE}" | tail -1 | awk '{print $3}')
if [[ "${total}" != "100.0%" ]]; then
    echo "FAIL: coverage ${total}, want 100.0%"
    go tool cover -func="${COVFILE}" | grep -v "100.0%"
    exit 1
fi

echo "PASS: coverage ${total}"
