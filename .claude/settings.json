{
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          { "type": "command", "command": "command -v wsh >/dev/null 2>&1 && wsh badge bell-exclamation --color '#e0b956' --priority 20 --beep || true" }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          { "type": "command", "command": "command -v wsh >/dev/null 2>&1 && wsh badge message-question --color '#e0b956' --priority 20 --beep || true" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "command -v wsh >/dev/null 2>&1 && wsh badge check --color '#58c142' --priority 10 || true" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          { "type": "command", "command": "command -v wsh >/dev/null 2>&1 && wsh badge message-question --color '#e0b956' --priority 20 --beep || true" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "command -v wsh >/dev/null 2>&1 && wsh badge --clear || true" }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(go vet *)",
      "Bash(go version *)",
      "Bash(bpftool btf *)",
      "Bash(gofmt *)",
      "Bash(llvm-readelf *)",
      "Bash(llvm-objdump *)",
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(go doc *)",
      "Bash(go generate *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git worktree *)",
      "Bash(git merge *)",
      "Bash(git stash *)",
      "Bash(git restore *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git check-ignore *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh api *)",
      "Bash(gh repo *)",
      "Bash(make *)"
    ]
  }
}
